{
  "enabled": true,
  "projectStack": "go",
  "goVersion": "1.26.1",
  "packageManager": "go modules",

  "testCommand": "go test -race ./...",
  "coverageCommand": "go test -coverprofile=coverage.out -covermode=atomic ./internal/...",
  "coverageSummaryPath": "coverage.out",
  "coverageFuncCommand": "go tool cover -func=coverage.out",
  "coverageHtmlCommand": "go tool cover -html=coverage.out -o coverage.html",
  "mutationCommand": null,

  "thresholds": {
    "lines": 100,
    "functions": 100,
    "branches": 100,
    "statements": 100
  },

  "policy": {
    "testFirst": true,
    "noSkipTests": true,
    "noTestDeletion": true,
    "requireBehaviorTests": true,
    "rejectWiringOnlyTests": true,
    "coverageRatchet": true,
    "failOnCoverageDrop": true
  },

  "blockCommitWithoutFreshGate": true,
  "gateFreshnessMinutes": 120,
  "smartStaleness": true,

  "excludeFromCoverage": [
    "main.go",
    "cmd/"
  ],

  "currentCoverage": {
    "total": 80.4,
    "packages": {
      "internal/parser": 94.0,
      "internal/registry": 94.1,
      "internal/executor": 88.0,
