      "internal/mcp": 80.0,
      "internal/nodeutil": 71.2,
      "internal/store": 64.4,
      "internal/paths": 66.7,
      "internal/sandbox": 58.1
    },
    "updatedAt": "2026-03-27"
  },

  "remainingGaps": {
    "mcp/Serve": "0% - calls server.ServeStdio which blocks on stdio",
    "mcp/DiscoverTools": "0% - requires running UDS daemon",
    "mcp/InvokeTool": "0% - requires running UDS daemon",
    "nodeutil/ResolveNodeRunner": "covered - 2 tests (tsx found, non-interactive fallback)",
    "nodeutil/EnsurePluginInstalled": "covered - 4 tests (already installed, installs on missing, install failure, same source/runtime)",
    "nodeutil/GetNpmChecksum": "covered - DI fix applied, 5 tests added",
    "paths/init": "unreachable os.UserHomeDir error fallback",
